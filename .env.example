# 复制为 .env 后填写（若用 python-dotenv 可自动加载；当前脚本优先读系统环境变量）
DEEPSEEK_API_KEY=sk-your-deepseek-key
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# 可选：设为 true 时仍使用旧版纯文本推送（默认飞书交互卡片）
# FEISHU_USE_TEXT=true

# 可选：微博 PC 接口仍 403 时，从浏览器登录 weibo.com 后复制完整 Cookie 粘贴到一行（勿泄露）
# WEIBO_COOKIE=SUB=...; SUBP=...

# 宿主机 host_trigger.py 可选鉴权（与 n8n HTTP 节点请求头 X-API-Key 一致）
# N8N_TRIGGER_KEY=随便写一串
# HOST_TRIGGER_PORT=8765
